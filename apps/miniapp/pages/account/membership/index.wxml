<import src="../../../templates/accessibility.wxml" />

<view class="accessibility-page level-{{accessibility.level}}">
  <view class="accessible-stage" style="{{accessibility.pageScaleStyle}}">
    <view class="page-shell">
      <view class="hero-card">
        <view class="hero-title">会员中心</view>
        <view class="hero-subtitle">{{demo.student.membership}}</view>
      </view>

      <view class="section-card">
        <view class="section-title">当前权益</view>
        <view class="list">
          <view class="list-item">
            <view class="list-title">课程服务权益</view>
            <view class="list-meta">基础课程、学习档案、每日任务、消息提醒</view>
          </view>
          <view class="list-item">
            <view class="list-title">活动参与权益</view>
            <view class="list-meta">可查看会员活动、优先报名学习沙龙</view>
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-title">升级方案</view>
        <view class="list">
          <view class="list-item" wx:for="{{demo.membershipPlans}}" wx:key="id">
            <view class="list-title">{{item.name}} · {{item.price}}</view>
            <view class="list-meta">{{item.duration}}</view>
            <view class="muted">{{item.benefits}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
  <template is="a11yControls" data="{{accessibility: accessibility}}" />
</view>
