<import src="../../../templates/accessibility.wxml" />

<view class="accessibility-page level-{{accessibility.level}}">
  <view class="accessible-stage" style="{{accessibility.pageScaleStyle}}">
    <view class="page-shell">

      <!-- 顶部蓝色卡片 -->
      <view class="hero-card">
        <view class="hero-title">学习进度总览</view>
        <view class="hero-subtitle">已完成 {{summary.lessonCompleted}} / {{summary.lessonTotal}} 课时</view>
        <view class="badge-row">
          <text class="badge" wx:if="{{summary.homeworkCompleted !== null && summary.homeworkTotal !== null}}">已完成 {{summary.homeworkCompleted}} / {{summary.homeworkTotal}} 份作业</text>
          <text class="badge" wx:if="{{summary.pendingMakeups > 0}}">待补课 {{summary.pendingMakeups}} 节</text>
          <text class="badge" wx:if="{{summary.level}}">{{summary.level}}</text>
          <!-- 
            这里可以根据实际需求添加更多与课程相关的徽章，
            例如：当前学习阶段、最近一次考试成绩等。
            这里优先展示后端返回的学习状态字段。
          -->
        </view>
      </view>

      <!-- 我的课程模块 -->
      <view class="section-card">
        <view class="section-title">我的课程</view>
        <view class="list" wx:if="{{enrolledCourses.length > 0}}">
          <view class="list-item arrow" wx:for="{{enrolledCourses}}" wx:key="id" data-id="{{item.id}}" bindtap="goToEnrolledCourseDetail">
            <view class="list-title">{{item.courseName}}</view>
            <view class="list-meta">{{item.className}} · {{item.teacher}}</view>
            <view class="muted">{{item.serviceStatus}}</view>
          </view>
        </view>
        <view wx:else class="empty-tip">
          <text>您还没有报名的课程。</text>
        </view>
      </view>

      <!-- 可购买课程模块 -->
      <view class="section-card">
        <view class="section-title">可购买课程</view>
        <view class="list" wx:if="{{purchasableCourses.length > 0}}">
          <view class="list-item arrow" wx:for="{{purchasableCourses}}" wx:key="id" data-id="{{item.id}}" bindtap="goToPurchasableCourseDetail">
            <view class="list-title">{{item.name}}</view>
            <view class="list-meta">{{item.type}} · {{item.duration}}</view>
            <view class="muted">{{item.summary}}</view>
          </view>
        </view>
        <view wx:else class="empty-tip">
          <text>当前课程都已开通，可进入“我的课程”继续查看。</text>
        </view>
      </view>

    </view>
  </view>
  <template is="a11yControls" data="{{accessibility: accessibility}}" />
</view>
