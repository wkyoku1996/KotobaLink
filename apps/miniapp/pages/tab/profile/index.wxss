.profile-hero {
  padding-bottom: 28rpx;
}

.profile-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-membership-btn {
  min-width: 168rpx;
  margin: 0;
  padding: 16rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 239, 0.16);
  color: #fff8ef;
  font-size: 24rpx;
  line-height: 1.2;
}

.hero-membership-btn::after {
  border: 1rpx solid rgba(255, 248, 239, 0.24);
  border-radius: 999rpx;
}

.profile-validity-card {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 239, 0.14);
}

.profile-validity-label {
  font-size: 22rpx;
  color: rgba(255, 248, 239, 0.76);
}

.profile-validity-value {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff8ef;
}

.archive-grid {
  margin-top: 18rpx;
  display: flex;
  gap: 16rpx;
}

.archive-card {
  flex: 1;
  padding: 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #eef6f2 0%, #f9fcfa 100%);
  border: 1rpx solid rgba(31, 106, 98, 0.08);
}

.archive-value {
  font-size: 38rpx;
  font-weight: 700;
  color: #1f6a62;
}

.archive-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #342a21;
}

.growth-summary-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.growth-summary-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fff9ef 0%, #fffdfa 100%);
  border: 1rpx solid rgba(206, 122, 42, 0.14);
}

.growth-summary-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #ce7a2a;
}

.growth-summary-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #342a21;
}

.trend-chart {
  margin-top: 22rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12rpx;
  min-height: 220rpx;
  padding: 20rpx 16rpx 6rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f5f8f3 0%, #fffdfa 100%);
}

.trend-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.trend-bars {
  width: 100%;
  min-height: 180rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 8rpx;
}

.trend-bar {
  width: 20rpx;
  border-radius: 999rpx 999rpx 0 0;
}

.trend-bar.lesson {
  background: #1f6a62;
}

.trend-bar.homework {
  background: #ce7a2a;
}

.trend-bar.quiz {
  background: #5f7ec9;
}

.trend-label {
  font-size: 22rpx;
  color: #6e6458;
}

.trend-legend {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.legend-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #6e6458;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
}

.legend-dot.lesson {
  background: #1f6a62;
}

.legend-dot.homework {
  background: #ce7a2a;
}

.legend-dot.quiz {
  background: #5f7ec9;
}

.legend-dot.current {
  background: #1f6a62;
}

.legend-dot.previous {
  background: #ce7a2a;
}

.radar-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f5f8f3 0%, #fffdfa 100%);
}

.radar-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.radar-canvas-wrap {
  position: relative;
  width: 520rpx;
  height: 520rpx;
  margin: 0 auto;
  overflow: visible;
}

.radar-canvas {
  width: 520rpx;
  height: 520rpx;
  display: block;
}

.radar-label {
  position: absolute;
  font-size: 22rpx;
  font-weight: 700;
  color: #6e6458;
  white-space: nowrap;
}

.radar-label.top {
  top: 0;
  left: 50%;
  transform: translateX(-50%);
}

.radar-label.right-top {
  top: 110rpx;
  right: -8rpx;
}

.radar-label.right-bottom {
  right: -14rpx;
  bottom: 110rpx;
}

.radar-label.left-bottom {
  left: -10rpx;
  bottom: 110rpx;
}

.radar-label.left-top {
  top: 110rpx;
  left: -4rpx;
}

.skill-list {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.skill-row {
  min-width: 200rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #fffdfa;
  border: 1rpx solid rgba(108, 87, 63, 0.12);
}

.skill-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.skill-subline {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.skill-label,
.skill-score {
  font-size: 24rpx;
  font-weight: 700;
  color: #342a21;
}

.skill-delta {
  font-size: 22rpx;
  font-weight: 700;
  color: #1f6a62;
}

.lesson-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.timeline-list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: #ce7a2a;
  box-shadow: 0 0 0 8rpx rgba(206, 122, 42, 0.12);
}

.timeline-content {
  flex: 1;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #fffdfa;
  border: 1rpx solid rgba(108, 87, 63, 0.12);
}

.profile-subsection {
  margin-top: 22rpx;
}

.subsection-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #342a21;
}

.no-record {
  margin-top: 14rpx;
}
