<import src="../../../templates/accessibility.wxml" />

<view class="accessibility-page level-{{accessibility.level}}">
  <view class="accessible-stage" style="{{accessibility.pageScaleStyle}}">
    <view class="page-shell">
      <view class="hero-card schedule-hero">
        <view class="hero-title">本周课表</view>
        <view class="hero-subtitle">同一周内的不同课程、不同班级统一排在一张周课表里查看。</view>
        <view class="schedule-overview">
          <view class="schedule-chip">
            <text class="schedule-chip-value">{{weekView.courseCount}}</text>
            <text class="schedule-chip-label">进行中班级</text>
          </view>
          <view class="schedule-chip">
            <text class="schedule-chip-value">{{weekView.totalCount}}</text>
            <text class="schedule-chip-label">本周课程</text>
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-title">周课表</view>
        <view class="section-desc">本周 {{weekView.rangeLabel}}，按星期分组展示，点击课程标题进入详情。</view>
        <view class="schedule-weekly-board">
          <view class="schedule-week-row" wx:for="{{weekView.rows}}" wx:key="id">
            <view class="schedule-day-card {{item.isToday ? 'is-today' : ''}}">
              <view class="schedule-day-side">
                <view class="schedule-day-label">周{{item.weekLabel}}</view>
                <view class="schedule-day-date">{{item.dateLabel}}</view>
              </view>
              <view class="schedule-day-main">
                <view wx:if="{{item.courses.length}}" class="schedule-course-list">
                  <view class="schedule-course-row {{course.isActivity ? 'is-activity' : ''}}" wx:for="{{item.courses}}" wx:key="id" wx:for-item="course">
                    <view class="schedule-course-time">
                      <view class="schedule-time-start">{{course.startTime}}</view>
                      <view class="schedule-time-line"></view>
                      <view class="schedule-time-end">{{course.endTime}}</view>
                    </view>
                    <view class="schedule-course-content">
                      <view class="schedule-course-title tappable-title" data-course-id="{{course.courseId}}" data-lesson-id="{{course.lessonId}}" data-is-activity="{{course.isActivity}}" bindtap="openScheduleItem">{{course.title}}</view>
                      <view class="schedule-course-meta">{{course.classBrief}} · {{course.courseName}}</view>
                      <view class="schedule-course-sub">{{course.status}}</view>
                    </view>
                  </view>
                </view>
                <view wx:else class="schedule-empty-day">当天暂无课程</view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
  <template is="a11yControls" data="{{accessibility: accessibility}}" />
</view>
