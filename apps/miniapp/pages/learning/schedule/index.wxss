.schedule-hero {
  padding-bottom: 28rpx;
}

.schedule-overview {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.schedule-chip {
  flex: 1;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 239, 0.16);
}

.schedule-chip-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff8ef;
}

.schedule-chip-label {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 248, 239, 0.78);
}

.schedule-weekly-board {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.schedule-week-row {
  margin-top: 0;
}

.schedule-day-card {
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #edf6f2 0%, #f7fbf9 100%);
  border: 1rpx solid rgba(31, 106, 98, 0.08);
}

.schedule-day-card.is-today {
  box-shadow: 0 14rpx 28rpx rgba(31, 106, 98, 0.1);
  border-color: rgba(31, 106, 98, 0.16);
}

.schedule-day-side {
  width: 106rpx;
  flex-shrink: 0;
  padding: 16rpx 10rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.78);
  text-align: center;
}

.schedule-day-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #342a21;
}

.schedule-day-date {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #7d7469;
}

.schedule-day-main {
  flex: 1;
}

.schedule-course-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.schedule-course-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(31, 106, 98, 0.08);
}

.schedule-course-row.is-activity {
  background: rgba(255, 244, 233, 0.92);
  border-color: rgba(206, 122, 42, 0.16);
}

.schedule-course-time {
  width: 88rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #1f6a62;
}

.schedule-course-content {
  flex: 1;
}

.schedule-course-title {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
  word-break: break-word;
}

.tappable-title {
  text-decoration: underline;
}

.schedule-course-meta,
.schedule-course-sub {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #6b6a63;
  word-break: break-word;
}

.schedule-time-start,
.schedule-time-end {
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.2;
}

.schedule-time-line {
  width: 2rpx;
  height: 28rpx;
  margin: 8rpx 0;
  border-radius: 999rpx;
  background: rgba(122, 108, 92, 0.3);
}

.schedule-empty-day {
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  color: #7d7469;
}
