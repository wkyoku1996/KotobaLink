/* pages/assessment-detail/index.wxss */
.page-shell {
  padding-bottom: 40rpx;
}

.practice-options {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.practice-option {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fffdfa;
  border: 1rpx solid rgba(108, 87, 63, 0.12);
  font-size: 24rpx;
  color: #342a21;
}

.practice-option.is-active {
  border-color: rgba(31, 106, 98, 0.4);
  background: #eef6f2;
  color: #1f6a62;
}

.practice-input-wrap {
  margin-top: 16rpx;
}

.practice-input {
  width: 100%;
  min-height: 80rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #fffdfa;
  border: 1rpx solid rgba(108, 87, 63, 0.12);
  font-size: 24rpx;
  color: #342a21;
}

.action-row {
  margin-top: 20rpx;
}
